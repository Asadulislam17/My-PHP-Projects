# Application
APP_NAME="NextGen Real Estate"
APP_ENV=development
APP_URL=http://localhost/realestate/public 
APP_DEBUG=true
APP_KEY=your_secret_key_here_change_in_production
APP_LANG=en

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=realestate_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@realestate.com
MAIL_FROM_NAME="NextGen Real Estate"

# SMS (Twilio / local gateway)
SMS_DRIVER=log
SMS_API_KEY=
SMS_FROM=

# Payment
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_MODE=sandbox
BKASH_APP_KEY=
BKASH_APP_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Cache
CACHE_DRIVER=file
CACHE_TTL=3600

# Session
SESSION_LIFETIME=7200
SESSION_NAME=realestate_session

# Upload
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,gif
ALLOWED_VIDEO_TYPES=mp4,webm,mov

# Pagination
ITEMS_PER_PAGE=12

# Redis (optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
